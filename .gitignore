# ----------------------------------------------------------------------------
# EXCEPCIONES (archivos que SÍ deben versionarse)
# ----------------------------------------------------------------------------

# No ignorar READMEs
!README.md
!**/README.md

# No ignorar requirements
!requirements.txt
!requirements-dev.txt

# No ignorar configuraciones base
!config/config.json
!config/environments/*/smallworld.json

# No ignorar scripts de migración
!src/core/database/migrations/*.sql

# No ignorar ejemplos
!*.example
!*.sample
!*.template

# No ignorar documentación
!docs/architecture/*.md
!docs/api/*.md
!docs/operations/*.md

