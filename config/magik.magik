                show("=== ALTERNATIVAS ACTIVAS EN EL DATASET GIS ===")
                _for key _over vista.alternative_history.keys.elements()
                _loop
                    estado << vista.alternative_history[key]
                    show("  key: ", key, " | checkpoint: ", estado.checkpoint, " | mode: ", estado.mode)
                _endloop
            _endblock
