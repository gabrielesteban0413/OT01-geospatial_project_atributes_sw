        #IMPORTANTE : CODIGO PARA SABER SI EXISTE ATRIBUTO Y VALOR SEGUN ID 



                     _block
                vista << gis_program_manager.cached_dataset(:gis)
                vista.checkpoint("sheath_with_loc")
                sheath_with_locs << vista.collection(:sheath_with_loc)
                id_a_buscar << 3492000048815557863

                un_sheath_with_loc << sheath_with_locs.select(predicate.eq(:id, id_a_buscar)).an_element()

                _if un_sheath_with_loc _isnt _unset
                _then
                    _try
                        gsvalor << un_sheath_with_loc.mit_hub1 # cambiar 
                        show("valor es: " + gsvalor.write_string)
                    _when error
                        show("Fallo: El edificio se encontró, pero no tiene una propiedad 'mit_hub'.")
                    _endtry
                _else
                    show("Fallo: No se encontró el edificio con el ID " + id_a_buscar.write_string)
                _endif
            _endblock
            








            _block
                vista << gis_program_manager.cached_dataset(:gis)
                vista.checkpoint("building")
                buildings << vista.collection(:building)
                id_a_buscar << 3492000048811470165

                un_building << buildings.select(predicate.eq(:id, id_a_buscar)).an_element()

                _if un_building _isnt _unset
                _then
                    _try
                        gsvalor << un_building.insert_date # cambiar 
                        show("valor es: " + gsvalor.write_string)
                    _when error
                        show("Fallo: El edificio se encontró, pero no tiene una propiedad 'insert_date'.")
                    _endtry
                _else
                    show("Fallo: No se encontró el edificio con el ID " + id_a_buscar.write_string)
                _endif
            _endblock
            $




            #IMPORTANTE : MISMO CODIGO PERO SIN MENCIONAR ID 
            _block
                vista << gis_program_manager.cached_dataset(:gis)
                Ds_change_trackings << vista.collection(:change_tracking)
                un_Ds_change_tracking << Ds_change_trackings.an_element()

                _if un_Ds_change_tracking _isnt _unset
                _then
                    show("Éxito: Se encontró el primer edificio.")
                    _try
                        gsvalor << un_Ds_change_tracking.object_id
                        show("El estado de construcción es: " + name.write_string)
                    _when error
                        show("Fallo: El edificio se encontró, pero no tiene una propiedad 'insert_date'.")
                    _endtry
                _else
                    show("Fallo: No se encontró ningún edificio en la colección.")
                _endif
            _endblock
