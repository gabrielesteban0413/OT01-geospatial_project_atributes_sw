            # validar tipo  caracter string- number etc 

                _block
                design_ds << gis_program_manager.cached_dataset(:design_admin)
                alt_map << design_ds.collection(:swg_dsn_scheme_alternative_map)
                
                _for alt _over alt_map.select(predicate.eq(:dataset_name, "gis")).elements()
                _loop
                    nom << alt.alternative_name.write_string
                    _if nom.index_of_seq("PLAN_") _isnt _unset
                    _then
                        num_str << nom.slice_to_end(6)
                        num << num_str.as_number()
                        show("nom: ", nom, " | num_str: ", num_str, " | num: ", num, " | tipo: ", num.class_name)
                        _leave
                    _endif
                _endloop
            _endblock
            $


            # traer todo lo que trae esa colleccion 

                    _block
                design_ds << gis_program_manager.cached_dataset(:design_admin)
                alt_map << design_ds.collection(:swg_dsn_scheme_alternative_map)
                
                # Ver todos los campos del alt_map
                un_reg << alt_map.an_element()
                show("=== CAMPOS DE ALT_MAP ===")
                _for campo _over un_reg.record_exemplar.all_fields.elements()
                _loop
                    show("  ", campo.name, " = ", un_reg.perform(campo.name))
                _endloop
                
                # Ver cuantos registros hay
                show("Total registros alt_map: ", alt_map.size)
                
                # Ver los ultimos registros (los mas recientes)
                show("=== ULTIMOS 3 REGISTROS ===")
                todos << rope.new()
                _for alt _over alt_map.select(predicate.eq(:dataset_name, "gis")).elements()
                _loop
                    todos.add(alt)
                _endloop
                
                i << todos.size
                _for alt _over todos.elements()
                _loop
                    _if i <= todos.size _andif i >= todos.size - 2
                    _then
                        show("  id: ", alt.id, " | alternative_name: ", alt.alternative_name, " | scheme_id: ", alt.scheme_id)
                    _endif
                    i << i - 1
                _endloop
            _endblock
            $

                    "=== ULTIMOS 3 REGISTROS ==="
            "  id: " 1012 " | alternative_name: " "PLAN_1011" " | scheme_id: " 4281
            "  id: " 1020 " | alternative_name: " "PLAN_1019" " | scheme_id: " 4664
            "  id: " 1028 " | alternative_name: " "PLAN_1027" " | scheme_id: " 14974
            MagikSF>


        #identificar mundo 

                MagikSF>
            _block
                vista << gis_program_manager.cached_dataset(:gis)
                design_ds << gis_program_manager.cached_dataset(:design_admin)
                alt_map << design_ds.collection(:swg_dsn_scheme_alternative_map)
                esquemas << design_ds.collection(:swg_dsn_scheme)

                # Obtener el objeto
                underground_routes << vista.collection(:underground_route)
                un_objeto << underground_routes.select(predicate.eq(:id, 3492000048800395440)).an_element()

                # Ver todos los campos ds! del objeto
                show("=== CAMPOS DS! DEL OBJETO ===")
                _for campo _over un_objeto.record_exemplar.all_fields.elements()
                _loop
                    nom << campo.name.write_string
                    _if nom.index_of_seq("ds!") _isnt _unset _orif
                    nom.index_of_seq("world") _isnt _unset _orif
                    nom.index_of_seq("rwo") _isnt _unset
                    _then
                        show("  ", campo.name, " = ", un_objeto.perform(campo.name))
                    _endif
                _endloop
            _endblock
