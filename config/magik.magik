    #----------------------------------002_01_EJECUTABLES PRINCIPALES -----------------------------------------------------------------------------------------------------------------------------
           
           #traer todos los datos de una colleccion 

                    _block
                vista << gis_program_manager.cached_dataset(:gis)
                buildings << vista.collection(:building)
                un_objeto << buildings.select(predicate.eq(:id, 3492000048800395440)).an_element()

                show("=== TODOS LOS CAMPOS DEL OBJETO ===")
                _for campo _over un_objeto.record_exemplar.all_fields.elements()
                _loop
                    _try
                        val << un_objeto.perform(campo.name)
                        _if val _isnt _unset
                        _then
                            show("  ", campo.name, " = ", val)
                        _endif
                    _when error
                    _endtry
                _endloop
            _endblock
            $
                    



             #tener todas las conexiones de un elemento 

                            _block
                    objeto_id << 3492000048819396124
                    show("=== ESCANEANDO TODAS LAS BASES DE DATOS ===")
                    
                    _for ds _over gis_program_manager.cached_datasets()
                    _loop
                        _try
                            show("--- DATASET: ", ds, " ---")
                            _for col_name _over ds.collections.keys.elements()
                            _loop
                                _try
                                    col << ds.collection(col_name)
                                    encontrado << col.select(predicate.eq(:id, objeto_id)).an_element()
                                    _if encontrado _isnt _unset
                                    _then
                                        show("  ENCONTRADO en: ", col_name)
                                        _for campo _over encontrado.record_exemplar.all_fields.elements()
                                        _loop
                                            _try
                                                val << encontrado.perform(campo.name)
                                                _if val _isnt _unset
                                                _then
                                                    show("    ", campo.name, " = ", val)
                                                _endif
                                            _when error
                                            _endtry
                                        _endloop
                                    _endif
                                _when error
                                _endtry
                            _endloop
                        _when error
                        _endtry
                    _endloop
                    show("=== FIN ESCANEO ===")
                _endblock
                $       
                        
                        
                        
           
           
            #encontrar colleccion 
            Ds_building << vista.collection(:change_tracking)
            show(vista.collection(:change_tracking).select(predicate.eq(:id,13)).size > 0)

            #listarr todo collecciones 
            _for col _over vista.collections.fast_elements() _loop
            write(col.insert_date)
