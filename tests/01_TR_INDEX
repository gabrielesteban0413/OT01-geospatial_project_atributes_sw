    RUTA_BUSQUEDA = r"\\atlas.etb.com.co\VP_DESARROLLO_DE_RED_Y_SERVICIOS\G_Aprovisionamiento_Servicios_Datos_Internet\D3910_Carr_Diseno_fo"
